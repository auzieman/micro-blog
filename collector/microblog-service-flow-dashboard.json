      "targets": [{ "editorMode": "code", "expr": "100 * sum(rate(blog_api_requests_total{result!=\"success\"}[5m])) / clamp_min(sum(rate(blog_api_requests_total[5m])), 0.001)", "refId": "A" }],
      "title": "API Error Rate",
