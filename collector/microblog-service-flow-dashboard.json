        { "editorMode": "code", "expr": "sum(rate(blog_queue_messages_total{destination=\"blog.commands\",direction=\"consume\",result=\"success\"}[5m]))", "legendFormat": "Worker consume blog.commands", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(blog_message_publish_total{destination=\"blog.events\",result=\"success\"}[5m]))", "legendFormat": "Worker publish blog.events", "range": true, "refId": "C" },
        { "editorMode": "code", "expr": "sum(rate(blog_queue_messages_total{destination=\"blog.events\",direction=\"consume\",result=\"success\"}[5m]))", "legendFormat": "Projection consume blog.events", "range": true, "refId": "D" }
