{
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (route, result) (rate(blog_api_requests_total[5m]))", "legendFormat": "{{route}} {{result}}", "range": true, "refId": "A" }
      ],
      "title": "API Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "editorMode": "code", "expr": "sum(increase(blog_errors_total[15m]))", "refId": "A" } ],
      "title": "Errors (15m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(blog_api_duration_ms_bucket[5m])) by (le))", "refId": "A" } ],
      "title": "API p95 Latency",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 } ] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "editorMode": "code", "expr": "sum(increase(blog_api_requests_total{route=~\"/admin.*\",result!=\"success\"}[15m]))", "refId": "A" } ],
      "title": "Admin Route Errors (15m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "editorMode": "code", "expr": "sum(increase(blog_api_requests_total{route=\"/admin/import/drupal\",result=\"success\"}[30m]))", "refId": "A" } ],
      "title": "Drupal Imports (30m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
